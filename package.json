{
  "name": "todo-list-api",
  "version": "1.0.0",
  "description": "Task management API with MongoDB persistence",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "npm run client:build && node src/server.js",
    "dev": "nodemon src/server.js",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "todo",
    "tasks",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.6.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ]
  }
}
